<Window x:Class="Package_Converter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Package Converter" Height="800" Width="1400" Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="SlideInStoryboard">

            <!-- 左側群組：從左邊滑入 -->
            <DoubleAnimation Storyboard.TargetName="txt_OringePackage"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-500" To="0" Duration="0:0:0.35" BeginTime="0:0:0"/>
            <DoubleAnimation Storyboard.TargetName="txt_OringePackage"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0"/>

            <DoubleAnimation Storyboard.TargetName="lst_Package"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-500" To="0" Duration="0:0:0.35" BeginTime="0:0:0.12"/>
            <DoubleAnimation Storyboard.TargetName="lst_Package"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.12"/>

            <DoubleAnimation Storyboard.TargetName="dgBits_CMD"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-500" To="0" Duration="0:0:0.35" BeginTime="0:0:0.24"/>
            <DoubleAnimation Storyboard.TargetName="dgBits_CMD"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.24"/>

            <DoubleAnimation Storyboard.TargetName="dgBits"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-500" To="0" Duration="0:0:0.35" BeginTime="0:0:0.36"/>
            <DoubleAnimation Storyboard.TargetName="dgBits"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.36"/>

            <!-- 中右 / 右側群組：從右邊滑入 -->
            <DoubleAnimation Storyboard.TargetName="reCal_dgBits_CMD"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="500" To="0" Duration="0:0:0.35" BeginTime="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="reCal_dgBits_CMD"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="reCal_dgBits"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="500" To="0" Duration="0:0:0.35" BeginTime="0:0:0.30"/>
            <DoubleAnimation Storyboard.TargetName="reCal_dgBits"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" BeginTime="0:0:0.30"/>

            <DoubleAnimation Storyboard.TargetName="btn_ReCal"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="400" To="0" Duration="0:0:0.30" BeginTime="0:0:0.42"/>
            <DoubleAnimation Storyboard.TargetName="btn_ReCal"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.30" BeginTime="0:0:0.42"/>

            <DoubleAnimation Storyboard.TargetName="btnClearPackage"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="400" To="0" Duration="0:0:0.30" BeginTime="0:0:0.54"/>
            <DoubleAnimation Storyboard.TargetName="btnClearPackage"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.30" BeginTime="0:0:0.54"/>

            <DoubleAnimation Storyboard.TargetName="btnPastePackage"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="400" To="0" Duration="0:0:0.30" BeginTime="0:0:0.66"/>
            <DoubleAnimation Storyboard.TargetName="btnPastePackage"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.30" BeginTime="0:0:0.66"/>

            <!-- 小標籤 -->
            <DoubleAnimation Storyboard.TargetName="lbl_RemoveMSB"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-200" To="0" Duration="0:0:0.28" BeginTime="0:0:0.60"/>
            <DoubleAnimation Storyboard.TargetName="lbl_RemoveMSB"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28" BeginTime="0:0:0.60"/>

            <DoubleAnimation Storyboard.TargetName="lbl_Arrow"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-200" To="0" Duration="0:0:0.28" BeginTime="0:0:0.66"/>
            <DoubleAnimation Storyboard.TargetName="lbl_Arrow"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28" BeginTime="0:0:0.66"/>

            <DoubleAnimation Storyboard.TargetName="lbl_Reorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-200" To="0" Duration="0:0:0.28" BeginTime="0:0:0.72"/>
            <DoubleAnimation Storyboard.TargetName="lbl_Reorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28" BeginTime="0:0:0.72"/>

        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Viewbox Stretch="Fill">
        <Canvas Height="800" Width="1400" Background="Black">

            <Button x:Name="btnPastePackage" Content="貼上封包"
                    Canvas.Left="1162" Canvas.Top="433"
                    Width="205" Height="30"
                    Click="btnPastePackage_Click"
                    Background="#FF191717" Foreground="#FFF3A71F"
                    BorderBrush="#FFF1E0E0" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Opacity="0">
                <Button.RenderTransform>
                    <TranslateTransform X="0"/>
                </Button.RenderTransform>
            </Button>

            <Button x:Name="btnClearPackage" Content="清除"
                    Canvas.Left="944" Canvas.Top="433"
                    Width="205" Height="30"
                    Click="btnClearPackage_Click"
                    Background="#FF191717" Foreground="#FFF3A71F"
                    BorderBrush="#FFF1E0E0" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Opacity="0">
                <Button.RenderTransform>
                    <TranslateTransform X="0"/>
                </Button.RenderTransform>
            </Button>

            <Button x:Name="btn_ReCal" Content="更新列表"
      Canvas.Left="725" Canvas.Top="433"
      Width="205" Height="30"
      Background="#FF191717" Foreground="#FFF3A71F"
      BorderBrush="#FFF1E0E0" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top" Click="btn_ReCal_Click"
      Opacity="0">
                <Button.RenderTransform>
                    <TranslateTransform X="0"/>
                </Button.RenderTransform>
            </Button>

            <TextBox x:Name="txt_OringePackage"
                     Canvas.Left="33" Canvas.Top="24"
                     Width="1334" Height="97"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Background="#FF424040" Foreground="#FFF7922C" KeyDown="txt_OringePackage_KeyDown" HorizontalAlignment="Left" VerticalAlignment="Center"
                     Opacity="0">
                <TextBox.RenderTransform>
                    <TranslateTransform X="0"/>
                </TextBox.RenderTransform>
            </TextBox>

            <ListView x:Name="lst_Package"
                      Canvas.Left="33" Canvas.Top="137"
                      Width="1334" Height="285"
                      Foreground="#FFF7922C" Background="#FF3C3C3C"
                      FontSize="20" SelectionChanged="lst_Package_SelectionChanged" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Opacity="0">
                <ListView.RenderTransform>
                    <TranslateTransform X="0"/>
                </ListView.RenderTransform>

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Index" DisplayMemberBinding="{Binding index}" Width="80"/>
                        <GridViewColumn Header="Time" DisplayMemberBinding="{Binding time}" Width="200"/>
                        <GridViewColumn Header="R/T"  Width="100"/>
                        <GridViewColumn Header="Data" DisplayMemberBinding="{Binding data}" Width="250"/>

                        <GridViewColumn Header="位元" Width="80"/>
                    </GridView>
                </ListView.View>

            </ListView>

            <DataGrid x:Name="dgBits"
                  AutoGenerateColumns="False"
                  Foreground="Black"
                  Background="White"
                  FontSize="20"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All" Canvas.Left="33" Canvas.Top="579" CanUserAddRows="False" HorizontalAlignment="Center" VerticalAlignment="Top"
                  Opacity="0">
                <DataGrid.RenderTransform>
                    <TranslateTransform X="0"/>
                </DataGrid.RenderTransform>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Byte" Binding="{Binding ByteIndex}" Width="80"/>
                    <DataGridTextColumn Header="HEX" Binding="{Binding Hex}" Width="80"/>

                    <DataGridTextColumn Header="b7" Binding="{Binding b7}" Width="60"/>
                    <DataGridTextColumn Header="b6" Binding="{Binding b6}" Width="60"/>
                    <DataGridTextColumn Header="b5" Binding="{Binding b5}" Width="60"/>
                    <DataGridTextColumn Header="b4" Binding="{Binding b4}" Width="60"/>
                    <DataGridTextColumn Header="b3" Binding="{Binding b3}" Width="60"/>
                    <DataGridTextColumn Header="b2" Binding="{Binding b2}" Width="60"/>
                    <DataGridTextColumn Header="b1" Binding="{Binding b1}" Width="60"/>
                    <DataGridTextColumn Header="b0" Binding="{Binding b0}" Width="60"/>
                </DataGrid.Columns>

            </DataGrid>

            <DataGrid x:Name="dgBits_CMD"
      AutoGenerateColumns="False"
      Foreground="Black"
      Background="White"
      FontSize="20"
      HeadersVisibility="Column"
      GridLinesVisibility="All" Canvas.Left="33" Canvas.Top="494" CanUserAddRows="False" HorizontalAlignment="Center" VerticalAlignment="Center"
      Opacity="0">
                <DataGrid.RenderTransform>
                    <TranslateTransform X="0"/>
                </DataGrid.RenderTransform>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Byte" Binding="{Binding ByteIndex}" Width="80"/>
                    <DataGridTextColumn Header="HEX" Binding="{Binding Hex}" Width="80"/>

                    <DataGridTextColumn Header="b7" Binding="{Binding b7}" Width="60"/>
                    <DataGridTextColumn Header="b6" Binding="{Binding b6}" Width="60"/>
                    <DataGridTextColumn Header="b5" Binding="{Binding b5}" Width="60"/>
                    <DataGridTextColumn Header="b4" Binding="{Binding b4}" Width="60"/>
                    <DataGridTextColumn Header="b3" Binding="{Binding b3}" Width="60"/>
                    <DataGridTextColumn Header="b2" Binding="{Binding b2}" Width="60"/>
                    <DataGridTextColumn Header="b1" Binding="{Binding b1}" Width="60"/>
                    <DataGridTextColumn Header="b0" Binding="{Binding b0}" Width="60"/>
                </DataGrid.Columns>

            </DataGrid>

            <DataGrid x:Name="reCal_dgBits"
      AutoGenerateColumns="False"
      Foreground="Black"
      Background="White"
      FontSize="20"
      HeadersVisibility="Column"
      GridLinesVisibility="All" Canvas.Left="725" Canvas.Top="579" CanUserAddRows="False" HorizontalAlignment="Center" VerticalAlignment="Center"
      Opacity="0">
                <DataGrid.RenderTransform>
                    <TranslateTransform X="0"/>
                </DataGrid.RenderTransform>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Byte" Binding="{Binding ByteIndex}" Width="80"/>
                    <DataGridTextColumn Header="HEX" Binding="{Binding Hex}" Width="80"/>

                    <DataGridTextColumn Header="b7" Binding="{Binding b7}" Width="60"/>
                    <DataGridTextColumn Header="b6" Binding="{Binding b6}" Width="60"/>
                    <DataGridTextColumn Header="b5" Binding="{Binding b5}" Width="60"/>
                    <DataGridTextColumn Header="b4" Binding="{Binding b4}" Width="60"/>
                    <DataGridTextColumn Header="b3" Binding="{Binding b3}" Width="60"/>
                    <DataGridTextColumn Header="b2" Binding="{Binding b2}" Width="60"/>
                    <DataGridTextColumn Header="b1" Binding="{Binding b1}" Width="60"/>
                    <DataGridTextColumn Header="b0" Binding="{Binding b0}" Width="60"/>
                </DataGrid.Columns>

            </DataGrid>

            <DataGrid x:Name="reCal_dgBits_CMD"
AutoGenerateColumns="False"
Foreground="Black"
Background="White"
FontSize="20"
HeadersVisibility="Column"
GridLinesVisibility="All" Canvas.Left="725" Canvas.Top="494" CanUserAddRows="False" HorizontalAlignment="Center" VerticalAlignment="Center"
Opacity="0">
                <DataGrid.RenderTransform>
                    <TranslateTransform X="0"/>
                </DataGrid.RenderTransform>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Byte" Binding="{Binding ByteIndex}" Width="80"/>
                    <DataGridTextColumn Header="HEX" Binding="{Binding Hex}" Width="80"/>

                    <DataGridTextColumn Header="b7" Binding="{Binding b7}" Width="60"/>
                    <DataGridTextColumn Header="b6" Binding="{Binding b6}" Width="60"/>
                    <DataGridTextColumn Header="b5" Binding="{Binding b5}" Width="60"/>
                    <DataGridTextColumn Header="b4" Binding="{Binding b4}" Width="60"/>
                    <DataGridTextColumn Header="b3" Binding="{Binding b3}" Width="60"/>
                    <DataGridTextColumn Header="b2" Binding="{Binding b2}" Width="60"/>
                    <DataGridTextColumn Header="b1" Binding="{Binding b1}" Width="60"/>
                    <DataGridTextColumn Header="b0" Binding="{Binding b0}" Width="60"/>
                </DataGrid.Columns>

            </DataGrid>
            <Label x:Name="lbl_RemoveMSB" Content="去MSB" Canvas.Left="674" Canvas.Top="518" Foreground="#FFF19A50" HorizontalAlignment="Left" VerticalAlignment="Top" Width="54" Height="28"
                   Opacity="0">
                <Label.RenderTransform>
                    <TranslateTransform X="0"/>
                </Label.RenderTransform>
            </Label>
            <Label x:Name="lbl_Arrow" Content="->>" Canvas.Left="683" Canvas.Top="567" Foreground="#FFF19A50" HorizontalAlignment="Left" VerticalAlignment="Top" Width="48" Height="34"
                   Opacity="0">
                <Label.RenderTransform>
                    <TranslateTransform X="0"/>
                </Label.RenderTransform>
            </Label>
            <Label x:Name="lbl_Reorder" Content="+ 重排" Canvas.Left="675" Canvas.Top="543" Foreground="#FFF19A50" HorizontalAlignment="Center" VerticalAlignment="Top" Width="51" Height="28"
                   Opacity="0">
                <Label.RenderTransform>
                    <TranslateTransform X="0"/>
                </Label.RenderTransform>
            </Label>

        </Canvas>
    </Viewbox>
</Window>
